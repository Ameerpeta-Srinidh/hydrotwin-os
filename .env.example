# HydroTwin OS — Environment Variables Template
# Copy this file to .env and fill in the missing API keys.

# ==========================================
# 🌍 External APIs (Plane 3 & Plane 4)
# ==========================================

# ElectricityMaps API (Grid Carbon Intensity)
# Required for dynamic Pareto reward adjustment (alpha/gamma shifting).
# Get a free API key at: https://api.electricitymap.org
ELECTRICITY_MAPS_API_KEY="your_electricity_maps_token_here"

# NOAA Climate Data Online API (Ambient Weather Validation)
# Required for heatwave anomaly correlation.
# Get a free API key at: https://www.ncdc.noaa.gov/cdo-web/token
NOAA_WEATHER_API_KEY="your_noaa_token_here"

# WRI Aqueduct API (Water Stress Index)
# Used to determine local basin water scarcity for evaporative cooling constraints.
# (Currently uses a mocked fallback if left empty)
WRI_AQUEDUCT_API_KEY=""

# ==========================================
# ⚙️ Infrastructure config (Plane 2)
# ==========================================

# Kafka Broker
KAFKA_BOOTSTRAP_SERVERS="localhost:9092"

# InfluxDB Telemetry Time-Series
INFLUXDB_URL="http://localhost:8086"
INFLUXDB_TOKEN="supersecrettoken-hydrotwin-2026"
INFLUXDB_ORG="hydrotwin"
INFLUXDB_BUCKET="telemetry"

# ==========================================
# 📊 User Interface (Plane 5)
# ==========================================

# Dashboard Admin Credentials
DASHBOARD_ADMIN_USER="admin"
DASHBOARD_ADMIN_PASS="hydrotwin_admin"
